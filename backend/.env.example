ADMIN_API_KEY=change-me
LOG_LEVEL=INFO
ALGORITHM=round_robin

REQUEST_TIMEOUT_SECONDS=15
CONNECT_TIMEOUT_SECONDS=3
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=5
HEALTHY_THRESHOLD=2
UNHEALTHY_THRESHOLD=3
MAX_REQUEST_BODY_BYTES=10485760
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW_SECONDS=60

ALLOW_PRIVATE_BACKENDS=true
ALLOWED_BACKEND_HOSTS=backend-fast,backend-slow,backend-unstable
CORS_ORIGINS=http://localhost:4200,https://loadbalancer-chi.vercel.app
EXPOSE_SELECTED_BACKEND_HEADER=true
SEED_BACKENDS_JSON=[{"id":"fast","name":"Fast API","url":"http://backend-fast:9001","weight":3},{"id":"slow","name":"Slow API","url":"http://backend-slow:9002","weight":1},{"id":"unstable","name":"Unstable API","url":"http://backend-unstable:9003","weight":1}]

# Supabase Postgres runtime connection. Keep this only on the backend.
DATABASE_URL_RUNTIME=
DATABASE_REQUIRED=false
DATABASE_TRANSACTION_POOLER=false
DATABASE_APPLICATION_NAME=loadflow-api
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=600

TELEMETRY_QUEUE_MAX_SIZE=10000
TELEMETRY_BATCH_SIZE=250
TELEMETRY_FLUSH_INTERVAL_MS=500
TELEMETRY_LOCK_TIMEOUT_SECONDS=300

LOAD_TEST_TARGET_URL=http://localhost:8080/api/demo

# Live API neural-flow event stream
LIVE_API_EVENTS_ENABLED=true
LIVE_API_EVENT_HISTORY_SIZE=10000
LIVE_API_SUBSCRIBER_QUEUE_SIZE=10000
LIVE_API_KEEPALIVE_SECONDS=15
